# Production environment variables for Lexo Backend
# Copy this file to .env and fill in the values

# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_USER=lexo
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=lexo_db

# Full URL used by the app (async driver)
DATABASE_URL=postgresql+asyncpg://lexo:your_secure_password_here@localhost:5432/lexo_db

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ===========================================
# API Settings
# ===========================================
API_PORT=8000
# CORS_ORIGINS: frontend URL(s), comma-separated. Never use * in production.
CORS_ORIGINS=https://your-frontend.com
ENVIRONMENT=production

# ===========================================
# Game Settings
# ===========================================
GAME_DURATION=60
LETTER_POOL_SIZE=16
MIN_WORD_LENGTH=2

# ===========================================
# WebSocket Settings
# ===========================================
WS_GRACE_PERIOD_SECONDS=10
WS_TOKEN_CHECK_INTERVAL_SECONDS=300
WS_PING_INTERVAL_SECONDS=25

# ===========================================
# App Version Gating
# ===========================================
APP_MIN_VERSION=1.0.0
APP_LATEST_VERSION=1.0.0
APP_UPDATE_URL=https://play.google.com/store/apps/details?id=com.ardacey.lexo
APP_FORCE_UPDATE=false

# ===========================================
# Observability
# ===========================================
SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=INFO

# Set to "true" to enable the Prometheus /metrics endpoint
ENABLE_METRICS=true
